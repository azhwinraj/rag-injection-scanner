# RAG Injection Scanner — Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to version control

# LLM Provider — groq (free) or anthropic (production)
LLM_PROVIDER=groq

# Groq API Key — get yours free at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Anthropic API Key — only needed if LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_anthropic_api_key_here